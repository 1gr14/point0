{
  "name": "point0",
  "version": "0.1.0",
  "homepage": "https://github.com/devp0nt/point0#readme",
  "bugs": {
    "url": "https://github.com/devp0nt/point0/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Sergei Dmitriev",
    "url": "https://p0nt.dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devp0nt/point0.git"
  },
  "workspaces": {
    "packages": [
      "packages/**",
      "examples/**"
    ],
    "catalog": {
      "react": "^19.0.0",
      "react-dom": "^19.0.0",
      "@tanstack/react-query": "^5.0.0",
      "@devp0nt/error0": "^1.0.0-next.38",
      "@devp0nt/route0": "^1.0.0-next.61",
      "@unhead/react": "^2.1.2",
      "zod": "^4.0.0"
    }
  },
  "files": [
    "packages/**/dist/**/*",
    "packages/**/src/**/*",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun run build:watch",
    "build": "bun --filter '@point0/core' build && bun --filter '@point0/compiler' build && bun --filter '@point0/engine' build && bun --filter '@point0/react-dom' build && bun --filter '@point0/wouter' build && bun --filter '@point0/cookies-store' build",
    "build:watch": "bun run --parallel --if-present --filter '@point0/*' build:watch",
    "testa": "bun run scripts/test-parallel.ts",
    "testap": "cross-env SLOW_TESTS_NOT_SLOW=1 bun run scripts/test-parallel.ts",
    "tests": "cross-env SLOW_TESTS_ONLY=1 bun run scripts/test-parallel.ts",
    "testf": "cross-env NO_TEST_UTILS_TESTS=1 NO_SLOW_TESTS=1 bun run scripts/test-parallel.ts",
    "testfu": "cross-env NO_SLOW_TESTS=1 bun run scripts/test-parallel.ts",
    "testnl": "cross-env THROW_ON_HELPER_LOG_FN_CALLING=true bun test",
    "test:watch": "bun --filter '**' test:watch",
    "types": "bun --filter '**' types",
    "typesgo": "bun --filter '**' typesgo",
    "lint": "bun run lint:fix .",
    "lint:base": "oxlint .",
    "lint:type-aware": "oxlint . --type-aware",
    "lint:type-check": "oxlint . --type-aware --type-check",
    "lint:fix": "bun run lint:type-aware --fix",
    "format": "bun run format:fix .",
    "format:base": "oxfmt . --check",
    "format:fix": "oxfmt . --write",
    "pack:dist": "bun --filter './packages/**' pack:dist",
    "prepare": "husky",
    "clean": "rimraf packages/*/dist && rimraf packages-dist-npm && rimraf node_modules/.cache"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/npm": "^12.0.2",
    "@typescript/native-preview": "^7.0.0-dev.20260212.1",
    "execa": "^9.6.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.1",
    "oxfmt": "^0.33.0",
    "oxlint": "^1.48.0",
    "oxlint-tsgolint": "^0.14.0",
    "rimraf": "^6.0.1",
    "semantic-release": "^24.2.8",
    "zod": "catalog:"
  },
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=18.0.0"
  }
}
