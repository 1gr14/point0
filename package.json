{
  "name": "point0",
  "version": "0.2.3",
  "private": true,
  "homepage": "https://github.com/1gr14/point0#readme",
  "bugs": {
    "url": "https://github.com/1gr14/point0/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Sergei Dmitriev",
    "url": "https://1gr14.dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/1gr14/point0.git"
  },
  "workspaces": {
    "packages": [
      "packages/**",
      "examples/*"
    ],
    "catalog": {
      "react": "^19.2.7",
      "react-dom": "^19.2.7",
      "@types/react-dom": "^19.2.3",
      "@types/react": "^19.2.16",
      "@svgr/core": "^8.1.0",
      "@svgr/plugin-jsx": "^8.1.0",
      "@tanstack/react-query": "^5.101.0",
      "@tanstack/query-core": "^5.101.0",
      "superjson": "^2.2.6",
      "@1gr14/error0": "^0.4.7",
      "@1gr14/route0": "^0.1.0",
      "@1gr14/flat": "^0.1.4",
      "arktype": "^2.2.0",
      "wouter": "^3.10.0",
      "@types/bun": "^1.3.14",
      "source-map-support": "^0.5.21",
      "@types/source-map-support": "^0.5.10",
      "safe-stable-stringify": "^2.5.0",
      "@sinclair/typebox": "^0.34.49",
      "@unhead/react": "^3.1.1",
      "unhead": "^3.1.1",
      "superstruct": "^2.0.2",
      "valibot": "^1.4.1",
      "yup": "^1.7.1",
      "zod": "^4.4.3",
      "@typescript/native-preview": "^7.0.0-dev.20260604.1",
      "typescript": "^6.0.3",
      "prettier": "^3.8.3",
      "openapi-types": "^12.0.0",
      "commander": "^15.0.0",
      "@vitejs/plugin-react": "^6.0.2",
      "vite": "^8.0.16",
      "vite-bundle-analyzer": "^1.3.8",
      "vite-plugin-commonjs": "^0.10.4",
      "vite-plugin-svgr": "^5.2.0",
      "vite-tsconfig-paths": "^6.1.1",
      "babel-plugin-react-compiler": "^1.0.0",
      "tsdown": "^0.22.2",
      "@modelcontextprotocol/sdk": "^1.29.0",
      "@orama/orama": "^3.1.18",
      "@huggingface/transformers": "^4.2.0",
      "gray-matter": "^4.0.3",
      "fast-glob": "^3.3.2",
      "entities": "^7.0.1"
    }
  },
  "files": [
    "packages/**/dist/**/*",
    "packages/**/src/**/*",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun run build:watch",
    "build": "bun --filter './packages/*' build",
    "build:watch": "bun run --parallel --if-present --filter './packages/*' build:watch",
    "setup": "bun run scripts/setup.ts",
    "testa": "bun run scripts/test.ts all",
    "testf": "bun run scripts/test.ts fast",
    "tests": "bun run scripts/test.ts slow",
    "test:unit": "bun run scripts/test.ts unit",
    "test:int": "bun run scripts/test.ts int",
    "test:e2e": "bun run scripts/test.ts e2e",
    "test:plan": "bun run scripts/test.ts --plan",
    "testnl": "cross-env THROW_ON_HELPER_LOG_FN_CALLING=true bun test",
    "test:watch": "bun --filter '**' test:watch",
    "cov": "bun run scripts/test.ts fast --coverage",
    "cov:all": "bun run scripts/test.ts unit int --coverage",
    "cov:report": "bun run scripts/coverage.ts",
    "size": "bun run scripts/size.ts",
    "size:write": "bun run scripts/size.ts --write",
    "size:check": "bun run scripts/size.ts --check",
    "size:audit": "bun run scripts/size.ts --audit",
    "types": "bun --filter '**' types",
    "types:6": "bun --filter '**' types:6",
    "lint": "bun run lint:fix .",
    "lint:base": "cross-env NODE_OPTIONS='--max-old-space-size=16384' eslint --cache --cache-location node_modules/.cache/eslint/.eslintcache",
    "lint:fix": "bun run lint:base --fix",
    "lint:check": "bun run lint:base .",
    "format": "bun run format:fix .",
    "format:base": "prettier --cache --cache-location node_modules/.cache/prettier/.prettiercache --ignore-path .gitignore --ignore-path .prettierignore",
    "format:fix": "bun run format:base --write",
    "format:check": "bun run format:base --check .",
    "local-registry": "bun run scripts/local-registry.ts",
    "versions:write": "bun run scripts/sync-versions.ts --write",
    "versions:check": "bun run scripts/sync-versions.ts --check",
    "release": "bun run scripts/release.ts",
    "publish:packages": "bun run scripts/publish.ts",
    "check:channel": "bun run scripts/check-channel.ts",
    "prepare": "husky",
    "clean:dist": "rimraf packages/*/dist",
    "clean:all": "rimraf packages/*/dist && rimraf node_modules/.cache",
    "clean:nm": "rimraf ./**/node_modules"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@sodaru/yup-to-json-schema": "^2.0.1",
    "@typescript-eslint/utils": "^8.60.1",
    "@typescript/native-preview": "^7.0.0-dev.20260604.1",
    "concurrently": "^10.0.3",
    "esbuild": "0.28.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-no-only-tests": "^3.4.0",
    "execa": "^9.6.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "prettier-plugin-jsdoc": "^1.8.1",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "verdaccio": "^6.0.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "zod": "^4.4.3"
  },
  "engines": {
    "bun": ">=1.3.14"
  },
  "dependencies": {
    "@1gr14/error0": "^0.4.7",
    "@1gr14/flat": "^0.1.4",
    "@1gr14/route0": "^0.1.0"
  },
  "patchedDependencies": {
    "playwright-core@1.60.0": "patches/playwright-core@1.60.0.patch"
  }
}
