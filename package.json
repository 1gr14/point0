{
  "name": "point0",
  "version": "0.1.0",
  "homepage": "https://github.com/devp0nt/point0#readme",
  "bugs": {
    "url": "https://github.com/devp0nt/point0/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Sergei Dmitriev",
    "url": "https://p0nt.dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devp0nt/point0.git"
  },
  "workspaces": {
    "packages": [
      "packages/**",
      "examples/**"
    ],
    "catalog": {
      "react": "^19.2.7",
      "react-dom": "^19.2.7",
      "@types/react-dom": "^19.2.3",
      "@types/react": "^19.2.16",
      "@tanstack/react-query": "^5.101.0",
      "@tanstack/query-core": "^5.101.0",
      "superjson": "^2.2.6",
      "@devp0nt/error0": "^1.0.6",
      "@devp0nt/route0": "^1.1.1",
      "@devp0nt/flat0": "^1.2.0",
      "arktype": "^2.2.0",
      "wouter": "^3.10.0",
      "@types/bun": "^1.3.14",
      "safe-stable-stringify": "^2.5.0",
      "@sinclair/typebox": "^0.34.49",
      "@unhead/react": "^3.1.1",
      "unhead": "^3.1.1",
      "superstruct": "^2.0.2",
      "valibot": "^1.4.1",
      "yup": "^1.7.1",
      "zod": "^4.4.3",
      "@typescript/native-preview": "^7.0.0-dev.20260604.1",
      "typescript": "^6.0.3",
      "prettier": "^3.8.3",
      "openapi-types": "^12.0.0",
      "commander": "^15.0.0",
      "@vitejs/plugin-react": "^6.0.2",
      "vite": "^8.0.16",
      "vite-bundle-analyzer": "^1.3.8",
      "vite-plugin-commonjs": "^0.10.4",
      "vite-plugin-svgr": "^5.2.0",
      "vite-tsconfig-paths": "^6.1.1",
      "babel-plugin-react-compiler": "^1.0.0",
      "tsdown": "^0.22.2",
      "@modelcontextprotocol/sdk": "^1.29.0",
      "@orama/orama": "^3.1.18",
      "@huggingface/transformers": "^4.2.0",
      "gray-matter": "^4.0.3"
    }
  },
  "files": [
    "packages/**/dist/**/*",
    "packages/**/src/**/*",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun run build:watch",
    "build": "bun --filter './packages/*' build",
    "build:watch": "bun run --parallel --if-present --filter './packages/*' build:watch",
    "testa": "bun run scripts/test-parallel.ts",
    "testap": "cross-env SLOW_TESTS_NOT_SLOW=1 bun run scripts/test-parallel.ts",
    "tests": "cross-env SLOW_TESTS_ONLY=1 bun run scripts/test-parallel.ts",
    "testf": "cross-env NO_TEST_UTILS_TESTS=1 NO_SLOW_TESTS=1 bun run scripts/test-parallel.ts",
    "testfu": "cross-env NO_SLOW_TESTS=1 bun run scripts/test-parallel.ts",
    "testnl": "cross-env THROW_ON_HELPER_LOG_FN_CALLING=true bun test",
    "test:watch": "bun --filter '**' test:watch",
    "types": "bun --filter '**' types",
    "typesgo": "bun --filter '**' typesgo",
    "lint": "bun run lint:fix .",
    "lint:base": "cross-env NODE_OPTIONS='--max-old-space-size=16384' eslint --cache --cache-location node_modules/.cache/eslint/.eslintcache",
    "lint:fix": "bun run lint:base --fix",
    "format": "bun run format:fix .",
    "format:base": "prettier --cache --cache-location node_modules/.cache/prettier/.prettiercache --ignore-path .gitignore --ignore-path .prettierignore",
    "format:fix": "bun run format:base --write",
    "pack:dist": "bun --filter './packages/**' pack:dist",
    "pack:local-registry": "bun run scripts/pack-local-registry.ts",
    "prepare": "husky",
    "clean:dist": "rimraf packages/*/dist && rimraf packages-dist-npm",
    "clean:all": "rimraf packages/*/dist && rimraf packages-dist-npm && rimraf node_modules/.cache",
    "clean:nm": "rimraf ./**/node_modules"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@sodaru/yup-to-json-schema": "^2.0.1",
    "@typescript-eslint/utils": "^8.60.1",
    "@typescript/native-preview": "catalog:",
    "concurrently": "^10.0.3",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-no-only-tests": "^3.4.0",
    "execa": "^9.6.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "catalog:",
    "prettier-plugin-jsdoc": "^1.8.1",
    "rimraf": "^6.1.3",
    "semantic-release": "^25.0.3",
    "typescript": "catalog:",
    "typescript-eslint": "^8.60.1",
    "zod": "catalog:"
  },
  "overrides": {
    "zod": "^4.4.3"
  },
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=20.0.0"
  }
}
