{
  "name": "point0",
  "version": "0.1.0",
  "license": "MIT",
  "author": {
    "name": "Sergei Dmitriev",
    "url": "https://p0nt.dev"
  },
  "homepage": "https://github.com/devp0nt/point0#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devp0nt/point0.git"
  },
  "bugs": {
    "url": "https://github.com/devp0nt/point0/issues"
  },
  "type": "module",
  "files": [
    "packages/**/dist/**/*",
    "packages/**/src/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "bun run build:watch",
    "build": "bun --filter './packages/**' build",
    "build:watch": "bun --filter './packages/**' build:watch",
    "test": "bun --filter '**' test",
    "test:watch": "bun --filter '**' test:watch",
    "types": "bun --filter '**' types",
    "lint": "bun run lint:fix .",
    "lint:base": "eslint --cache --cache-location node_modules/.cache/eslint/.eslintcache",
    "lint:fix": "bun run lint:base --fix",
    "format": "bun run format:fix .",
    "format:base": "prettier --cache --cache-location node_modules/.cache/prettier/.prettiercache --ignore-path .gitignore --ignore-path .prettierignore",
    "format:fix": "bun run format:base --write",
    "pack:dist": "bun --filter './packages/**' pack:dist",
    "prepare": "husky",
    "clean": "rimraf packages/*/dist && rimraf packages-dist-npm && rimraf node_modules/.cache"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/npm": "^12.0.2",
    "concurrently": "^9.2.1",
    "eslint": "^9.36.0",
    "eslint-config-love": "^130.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.1",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "semantic-release": "^24.2.8"
  },
  "workspaces": {
    "packages": [
      "packages/**",
      "examples/**"
    ],
    "catalog": {
      "react": "^19.0.0",
      "react-dom": "^19.0.0",
      "@tanstack/react-query": "^5.0.0",
      "@devp0nt/error0": "^1.0.0-next.38",
      "@devp0nt/route0": "^1.0.0-next.43",
      "@unhead/react": "^2.0.19",
      "zod": "^4.0.0"
    }
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
