{
  "name": "ideanick-elysia-vite",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development bun run server/index.ts",
    "build": "cross-env NODE_ENV=production vite build --outDir dist/client && cross-env NODE_ENV=production vite build --ssr entry-server.tsx --outDir dist/server",
    "start": "cross-env NODE_ENV=production bun run server/index.ts",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "@devp0nt/route0": "^1.0.0-next.16",
    "@elysiajs/static": "^1.4.4",
    "elysia": "^1.4.12",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.22",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "cross-env": "^10.0.0",
    "typescript": "^5.0.0",
    "vite": "^7.1.10",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
