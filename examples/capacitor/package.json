{
  "name": "@point0/example-capacitor",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "point0 dev --hot",
    "generate": "point0 generate",
    "prisma:generate": "bunx prisma generate",
    "prisma:push": "bunx prisma db push",
    "build": "point0 build",
    "start": "cross-env NODE_ENV=production bun run ./dist/server/index.server.js",
    "clean": "rimraf dist",
    "types": "tsgo --noEmit",
    "types:6": "tsc --noEmit",
    "web": "bun run dev",
    "cap:sync": "bun run build && cap sync",
    "cap:copy": "bun run build && cap copy",
    "cap:add:ios": "cap add ios",
    "cap:add:android": "cap add android",
    "ios": "bun run build && cap sync ios && cap open ios",
    "android": "bun run build && cap sync android && cap open android"
  },
  "dependencies": {
    "@1gr14/error0": "^0.4.6",
    "@1gr14/route0": "^0.1.0",
    "@point0/compiler": "^0.2.1",
    "@point0/core": "^0.2.1",
    "@point0/engine": "^0.2.1",
    "@point0/react-dom": "^0.2.1",
    "@capacitor/core": "^8.4.0",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "prisma": "^7.8.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "server-only": "^0.0.1",
    "superjson": "^2.2.6"
  },
  "devDependencies": {
    "@svgr/core": "^8.1.0",
    "@svgr/plugin-jsx": "^8.1.0",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/android": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "cross-env": "^10.0.0",
    "ncp": "^2.0.0",
    "rimraf": "^6.0.1",
    "typescript": "^6.0.3"
  }
}
