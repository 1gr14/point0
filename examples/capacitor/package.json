{
  "name": "@point0/example-capacitor",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "point0 dev",
    "generate": "point0 generate",
    "prisma:generate": "bunx prisma generate",
    "prisma:push": "bunx prisma db push",
    "build": "point0 build",
    "start": "cross-env NODE_ENV=production bun run ./dist/server/index.server.js",
    "clean": "rimraf dist",
    "types": "tsc --noEmit",
    "typesgo": "tsgo --noEmit",
    "web": "bun run dev",
    "cap:sync": "bun run build && cap sync",
    "cap:copy": "bun run build && cap copy",
    "cap:add:ios": "cap add ios",
    "cap:add:android": "cap add android",
    "ios": "bun run build && cap sync ios && cap open ios",
    "android": "bun run build && cap sync android && cap open android"
  },
  "dependencies": {
    "@devp0nt/error0": "catalog:",
    "@devp0nt/route0": "catalog:",
    "@point0/compiler": "workspace:*",
    "@point0/cookies-store": "workspace:*",
    "@point0/core": "workspace:*",
    "@point0/engine": "workspace:*",
    "@point0/react-dom": "workspace:*",
    "@capacitor/core": "^7.4.3",
    "@prisma/adapter-libsql": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "prisma": "^7.5.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "server-only": "^0.0.1",
    "superjson": "^2.2.5"
  },
  "devDependencies": {
    "@svgr/core": "^8.1.0",
    "@svgr/plugin-jsx": "^8.1.0",
    "@types/bun": "^1.3.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@capacitor/cli": "^7.4.3",
    "@capacitor/android": "^7.4.3",
    "@capacitor/ios": "^7.4.3",
    "cross-env": "^10.0.0",
    "ncp": "^2.0.0",
    "rimraf": "^6.0.1",
    "typescript": "catalog:"
  }
}
