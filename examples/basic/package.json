{
  "name": "@point0/example-basic",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "point0 dev",
    "generate": "point0 generate",
    "build": "point0 build",
    "start": "cross-env NODE_ENV=production bun run ./dist/server/index.server.js",
    "clean": "rimraf dist",
    "types": "tsc --noEmit",
    "typesgo": "tsgo --noEmit",
    "prisma:reset": "cross-env NODE_ENV=development prisma migrate reset",
    "prisma:generate": "cross-env NODE_ENV=development prisma generate",
    "prisma:migrate:dev": "cross-env NODE_ENV=development prisma migrate dev",
    "prisma:migrate:deploy": "cross-env NODE_ENV=development prisma migrate deploy",
    "seed": "cross-env NODE_ENV=development bun run ./src/lib/seed.ts",
    "postinstall": "bun run prisma:migrate:deploy && bun run prisma:generate && bun run seed"
  },
  "dependencies": {
    "@devp0nt/error0": "catalog:",
    "@devp0nt/route0": "catalog:",
    "@faker-js/faker": "^10.4.0",
    "@point0/basic-auth": "workspace:*",
    "@point0/compiler": "workspace:*",
    "@point0/cookies-store": "workspace:*",
    "@point0/core": "workspace:*",
    "@point0/engine": "workspace:*",
    "@point0/openapi": "workspace:*",
    "@point0/react-dom": "workspace:*",
    "@prisma/adapter-libsql": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "dotenv": "^17.4.2",
    "prisma": "^7.5.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "server-only": "^0.0.1",
    "superjson": "^2.2.5"
  },
  "devDependencies": {
    "@svgr/core": "^8.1.0",
    "@svgr/plugin-jsx": "^8.1.0",
    "@tanstack/react-query-devtools": "^5.99.0",
    "@types/bun": "^1.3.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "cross-env": "^10.0.0",
    "ncp": "^2.0.0",
    "rimraf": "^6.0.1",
    "typescript": "catalog:"
  }
}
