{
  "name": "@point0/basic",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build:client": "bun build ./src/index.html --outdir ./dist/client --splitting --production --sourcemap --define process.env.IS_CLIENT='1'",
    "build:client:watch": "bun build ./src/index.html ./src/app.tsx ./src/lib/points.ready.ts --outdir ./dist/dev/client --sourcemap=inline --packages=external --watch",
    "build:client:check": "bun run clean && bun build ./src/index.html --outdir ./dist/client --outfile --splitting --sourcemap=external --define process.env.IS_CLIENT='1'",
    "build:server": "bun build ./src/index.server.ts --packages=external --outdir dist/server --target bun --splitting --sourcemap=external --production --define process.env.IT_WAS_BUILT='1'",
    "build:public": "ncp ./public ./dist/public",
    "build": "bun run clean && bun run build:client && bun run build:server && bun run build:public",
    "build2": "cross-env NODE_ENV=production TASK=build bun run src/index.server.ts",
    "dev:client": "cross-env NODE_ENV=development TARGET_ROOT_ID='client' bun --no-clear-screen ./src/index.server.ts",
    "dev:server": "cross-env NODE_ENV=development TARGET_ROOT_ID='server' bun --no-clear-screen --hot ./src/index.server.ts",
    "dev:separate": "concurrently 'bun run dev:server' 'bun run dev:client' --names 'server,client' --prefix-colors 'blue,green' --prefix '{name} |' --restart-tries -2 --restart-after 100",
    "generate": "cross-env TASK=generate bun run ./src/engine.ts",
    "generate:watch": "cross-env WATCH=1 TASK=generate-watch bun run ./src/engine.ts",
    "dev": "concurrently 'bun run dev:server' 'bun run dev:client' 'bun run generate:watch' --names 'server,client,points' --prefix-colors 'blue,green,gray' --prefix '{name} |'",
    "start": "cross-env NODE_ENV=production bun run ./dist/server/self/index.server.js",
    "start2": "cross-env NODE_ENV=production TARGET_ROOT_ID='server' bun run ./dist/server/self/index.server.js",
    "clean": "rimraf dist",
    "types": "tsc --noEmit"
  },
  "dependencies": {
    "@devp0nt/route0": "^1.0.0-next.36",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@svgr/core": "^8.1.0",
    "@svgr/plugin-jsx": "^8.1.0",
    "@types/bun": "^1.3.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.0.0",
    "ncp": "^2.0.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.0.0"
  }
}
