    "@point0/react-dom": "^0.1.0",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tanstack/react-query": "^5.101.0",
    "@unhead/react": "^3.1.1",
    "better-auth": "^1.6.14",
    "bun-plugin-tailwind": "^0.1.2",
    "dotenv": "^17.4.2",
    "openapi-types": "^12.0.0",
    "prisma": "^7.8.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "superjson": "^2.2.6",
    "tailwindcss": "^4.3.0",
    "unhead": "^3.1.1",
    "wouter": "^3.10.0"
  },
