{
  "name": "@point0/example-diy",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build:server": "cross-env NODE_ENV=production bun build ./entry/server.ts --outdir dist/server --target bun",
    "build:client": "cross-env NODE_ENV=production bun build ./entry/client.ts --outdir dist/client --splitting",
    "build": "bun run build:client && bun run build:server",
    "dev": "cross-env NODE_ENV=development bun --no-clear-screen --hot ./entry/server.ts",
    "start": "cross-env NODE_ENV=production bun run dist/server/index.js",
    "types": "tsc --noEmit"
  },
  "dependencies": {
    "@devp0nt/route0": "^1.0.0-next.16",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "cross-env": "^10.0.0",
    "typescript": "^5.0.0"
  }
}
