{
  "name": "@point0/example-vite",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "point0 dev",
    "generate": "point0 generate",
    "build": "point0 build",
    "start": "cross-env NODE_ENV=production bun run ./dist/server/main.js",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:down:volumes": "docker compose down --volumes",
    "clean": "rimraf dist",
    "types": "tsc --noEmit",
    "typesgo": "tsgo --noEmit",
    "prisma:reset": "cross-env NODE_ENV=development prisma migrate reset",
    "prisma:generate": "cross-env NODE_ENV=development prisma generate",
    "prisma:migrate:dev": "cross-env NODE_ENV=development prisma migrate dev",
    "prisma:migrate:deploy": "cross-env NODE_ENV=development prisma migrate deploy",
    "seed": "cross-env NODE_ENV=development bun run ./src/lib/seed.ts",
    "setup": "bun run prisma:migrate:deploy && bun run prisma:generate && point0 generate && bun run seed"
  },
  "dependencies": {
    "@devp0nt/error0": "catalog:",
    "@devp0nt/flat0": "catalog:",
    "@devp0nt/route0": "catalog:",
    "@point0/basic-auth": "workspace:*",
    "@point0/compiler": "workspace:*",
    "@point0/core": "workspace:*",
    "@point0/engine": "workspace:*",
    "@point0/openapi": "workspace:*",
    "@point0/react-dom": "workspace:*",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "catalog:",
    "@unhead/react": "catalog:",
    "dotenv": "^17.4.2",
    "openapi-types": "catalog:",
    "prisma": "^7.8.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "superjson": "catalog:",
    "tailwindcss": "^4.3.0",
    "unhead": "catalog:",
    "wouter": "catalog:"
  },
  "devDependencies": {
    "@svgr/core": "^8.1.0",
    "@tailwindcss/typography": "^0.5.19",
    "@svgr/plugin-jsx": "^8.1.0",
    "@tanstack/react-query-devtools": "^5.101.0",
    "@types/bun": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@faker-js/faker": "^10.4.0",
    "cross-env": "^10.0.0",
    "ncp": "^2.0.0",
    "rimraf": "^6.0.1",
