{
  "name": "@point0/vite",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build:client": "vite build --outDir ./dist/client",
    "build:client:watch": "vite build --outDir ./dist/client --watch",
    "build:client:check": "bun run clean && vite build --outDir ./dist/client",
    "build:server": "bun build ./src/index.server.ts --packages=external --outdir dist/server --target bun --sourcemap=external --production --define process.env.IS_CLIENT=''",
    "build:public": "ncp ./public ./dist/public",
    "build": "bun run clean && bun run build:client && bun run build:server && bun run build:public",
    "build2": "cross-env NODE_ENV=production TASK=build bun run src/engine.ts",
    "__dev:client": "cross-env NODE_ENV=development DEV_SERVER_TARGET=client IS_CLIENT='1' bun --no-clear-screen ./src/index.server.ts",
    "__dev:server": "cross-env NODE_ENV=development DEV_SERVER_TARGET=server IS_CLIENT='' bun --no-clear-screen --hot ./src/index.server.ts",
    "__dev:separate": "concurrently 'bun run dev:server' 'bun run dev:client' --names 'server,client' --prefix-colors 'blue,green' --prefix '{name} |' --restart-tries -2 --restart-after 100",
    "dev:client": "cross-env NODE_ENV=development TARGET_ROOT_ID='client' bun --no-clear-screen ./src/index.server.ts",
    "dev:server": "cross-env NODE_ENV=development TARGET_ROOT_ID='server' bun --no-clear-screen --hot ./src/index.server.ts",
    "dev:separate": "concurrently 'bun run dev:server' 'bun run dev:client' --names 'server,client' --prefix-colors 'blue,green' --prefix '{name} |' --restart-tries -2 --restart-after 100",
    "generate": "cross-env TASK=generate bun run ./src/engine.ts",
    "generate:watch": "cross-env WATCH=1 TASK=generate-watch bun run ./src/engine.ts",
    "dev": "concurrently 'bun run dev:server' 'bun run dev:client' 'bun run generate:watch' --names 'server,client,points' --prefix-colors 'blue,green,gray' --prefix '{name} |'",
    "start": "cross-env NODE_ENV=production bun run ./dist/server/self/index.server.js",
    "clean": "rimraf dist",
    "types": "tsc --noEmit"
  },
  "dependencies": {
    "@devp0nt/route0": "^1.0.0-next.36",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@svgr/core": "^8.1.0",
    "@svgr/plugin-jsx": "^8.1.0",
    "@types/bun": "^1.3.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.0.0",
    "ncp": "^2.0.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.0.0",
    "vite": "^7.2.2",
    "vite-plugin-commonjs": "^0.10.4",
    "vite-plugin-svgr": "^4.5.0",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
