generator client {
  provider   = "prisma-client"
  engineType = "binary"
  output     = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Idea {
  id          Int      @id @default(autoincrement())
  title       String
  content     String
  description String
  image       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  newsPosts IdeaNewsPost[]
}

model IdeaNewsPost {
  id        Int      @id @default(autoincrement())
  ideaId    Int
  idea      Idea     @relation(fields: [ideaId], references: [id])
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
