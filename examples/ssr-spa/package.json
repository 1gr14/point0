{
  "name": "@point0/ssr-spa",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build:server": "bun build ./src/entry-server.ts --outdir dist/server --target bun --sourcemap=external --production",
    "build:client": "bun build ./src/index.html --outdir ./dist/client --splitting --production --sourcemap=external --public-path /dist/client/ --define process.env.CLIENT_ONLY='1'",
    "build:client:check": "bun run clean && bun build ./src/index.html --outdir ./dist/client --splitting --sourcemap=external --define process.env.CLIENT_ONLY='1'",
    "build:public": "ncp ./public ./dist/public",
    "build": "bun run clean && bun run build:client && bun run build:server && bun run build:public",
    "dev:server": "cross-env NODE_ENV=development DEV_SERVER_TARGET=server bun --no-clear-screen --hot ./src/entry-server.ts",
    "dev:client": "cross-env NODE_ENV=development DEV_SERVER_TARGET=client bun --no-clear-screen ./src/entry-server.ts",
    "dev:separate": "concurrently 'bun run dev:server' 'bun run dev:client' --names 'server,client' --prefix-colors 'blue,green' --prefix '{name} |' --restart-tries -2 --restart-after 100",
    "generate": "bun run ./src/generator.ts",
    "generate:watch": "cross-env WATCH=1 bun run ./src/generator.ts",
    "dev": "concurrently 'bun run dev:server' 'bun run dev:client' 'bun run generate:watch' --names 'srvr,clnt,gnrt' --prefix-colors 'blue,green,gray' --prefix '{name} |'",
    "start": "cross-env NODE_ENV=production bun run ./dist/server/entry-server.js",
    "clean": "rimraf dist",
    "types": "tsc --noEmit"
  },
  "dependencies": {
    "@devp0nt/route0": "^1.0.0-next.31",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.0.0",
    "ncp": "^2.0.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.0.0"
  }
}
