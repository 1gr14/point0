{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!**/node_modules",
      "!**/.git",
      "!**/dist",
      "!**/dist-test",
      "!**/dist-npm",
      "!**/packages-dist-npm",
      "!**/.cache",
      "!**/.husky",
      "!**/temp",
      "!**/engine/tests/template",
      "!**/templates",
      "!**/points.lazy.ts",
      "!**/points.ready.ts",
      "!**/points.ts",
      "!**/wouter-routes.tsx",
      "!**/.bak"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "double",
      "semicolons": "asNeeded",
      "trailingCommas": "all",
      "arrowParentheses": "always"
    }
  },
  "json": {
    "formatter": {
      "trailingCommas": "none"
    }
  },
  "assist": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "domains": {
      "types": "all"
    },
    "rules": {
      "nursery": {
        "noFloatingPromises": "error",
        "noUnnecessaryConditions": "error"
      },
      "recommended": true,
      "a11y": {
        "noLabelWithoutControl": "off",
        "noStaticElementInteractions": "off",
        "useButtonType": "off",
        "useKeyWithClickEvents": "off"
      },
      "correctness": {},
      "complexity": {
        "noStaticOnlyClass": "off"
      },
      "security": {},
      "style": {
        "useTemplate": "off"
      },
      "suspicious": {
        "noExplicitAny": "off"
      }
    }
  }
}
