{
  "name": "@point0/docs",
  "version": "0.2.5",
  "license": "MIT",
  "author": {
    "name": "Sergei Dmitriev",
    "url": "https://1gr14.dev"
  },
  "homepage": "https://github.com/1gr14/point0#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/1gr14/point0.git",
    "directory": "packages/docs"
  },
  "bugs": {
    "url": "https://github.com/1gr14/point0/issues"
  },
  "type": "module",
  "engines": {
    "bun": ">=1.3.14"
  },
  "sideEffects": false,
  "bin": {
    "point0-docs-mcp": "dist/mcp.js"
  },
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "": [
        "./dist/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*",
    "content/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build:content": "bun ./scripts/build-content.ts",
    "build": "bun run build:content && tsdown",
    "build:watch": "tsdown --watch",
    "test": "bun test ./tests",
    "test:watch": "bun test --watch ./tests",
    "types": "tsgo --noEmit -p tsconfig.build.json",
    "types:6": "tsc --noEmit -p tsconfig.build.json",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@orama/orama": "^3.1.18",
    "gray-matter": "^4.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^20.0.0",
    "github-slugger": "^2.0.0",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
