{
  "name": "@point0/wouter",
  "version": "0.1.0",
  "license": "MIT",
  "author": {
    "name": "Sergei Dmitriev",
    "url": "https://p0nt.dev"
  },
  "homepage": "https://github.com/devp0nt/point0#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devp0nt/point0.git",
    "directory": "packages/wouter"
  },
  "bugs": {
    "url": "https://github.com/devp0nt/point0/issues"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*",
    "src/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "test": "bun test ./tests",
    "test:watch": "bun test --watch ./tests",
    "types": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "peerDependencies": {
    "@point0/core": "workspace:*",
    "wouter": "^3.7.1",
    "react": "catalog:",
    "react-dom": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@devp0nt/error0": "catalog:",
    "@devp0nt/route0": "catalog:",
    "@unhead/react": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "^1.2.22",
    "@types/node": "^20.0.0",
    "esbuild-fix-imports-plugin": "^1.0.22",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
