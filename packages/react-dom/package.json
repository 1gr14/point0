{
  "name": "@point0/react-dom",
  "version": "0.1.0",
  "license": "MIT",
  "author": {
    "name": "Sergei Dmitriev",
    "url": "https://p0nt.dev"
  },
  "homepage": "https://github.com/devp0nt/point0#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devp0nt/point0.git",
    "directory": "packages/react-dom"
  },
  "bugs": {
    "url": "https://github.com/devp0nt/point0/issues"
  },
  "type": "module",
  "sideEffects": false,
  "typesVersions": {
    "*": {
      "mount": [
        "./dist/mount.d.ts"
      ],
      "router": [
        "./dist/router.d.ts"
      ],
      "testing": [
        "./dist/testing.d.ts"
      ]
    }
  },
  "exports": {
    "./mount": {
      "types": "./dist/mount.d.ts",
      "import": "./dist/mount.js"
    },
    "./router": {
      "types": "./dist/router.d.ts",
      "import": "./dist/router.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js"
    }
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "test": "bun test ./tests",
    "test:watch": "bun test --watch ./tests",
    "types": "tsc --noEmit -p tsconfig.build.json",
    "typesgo": "tsgo --noEmit -p tsconfig.build.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "pack:dist": "rimraf ../../packages-dist-npm && bun ../../scripts/transform-package-for-publish.ts && mkdir -p ../../packages-dist-npm/react-dom && npm pack --pack-destination ../../packages-dist-npm/react-dom --silent && (cd ../../packages-dist-npm/react-dom && tar -xzf *.tgz && cp -r package/* . && rm -rf package && rm *.tgz) && bun ../../scripts/restore-package.ts",
    "prepublishOnly": "bun ../../scripts/transform-package-for-publish.ts",
    "postpublish": "bun ../../scripts/restore-package.ts"
  },
  "peerDependencies": {
    "@devp0nt/route0": "catalog:",
    "@point0/core": "workspace:*",
    "react": "catalog:",
    "react-dom": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "wouter": "catalog:"
  },
  "devDependencies": {
    "react": "catalog:",
    "react-dom": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@devp0nt/route0": "catalog:",
    "@point0/core": "workspace:*",
    "wouter": "catalog:",
    "@types/bun": "catalog:",
    "@types/node": "^20.0.0",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
