{
  "name": "@point0/react-dom",
  "version": "0.1.6",
  "license": "MIT",
  "author": {
    "name": "Sergei Dmitriev",
    "url": "https://1gr14.dev"
  },
  "homepage": "https://github.com/1gr14/point0#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/1gr14/point0.git",
    "directory": "packages/react-dom"
  },
  "bugs": {
    "url": "https://github.com/1gr14/point0/issues"
  },
  "type": "module",
  "engines": {
    "bun": ">=1.3.14"
  },
  "sideEffects": false,
  "typesVersions": {
    "*": {
      "mount": [
        "./dist/mount.d.ts"
      ],
      "router": [
        "./dist/router.d.ts"
      ]
    }
  },
  "exports": {
    "./mount": {
      "types": "./dist/mount.d.ts",
      "import": "./dist/mount.js"
    },
    "./router": {
      "types": "./dist/router.d.ts",
      "import": "./dist/router.js"
    }
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "test": "bun test ./tests",
    "test:watch": "bun test --watch ./tests",
    "types": "tsgo --noEmit -p tsconfig.build.json",
    "types:6": "tsc --noEmit -p tsconfig.build.json",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "peerDependencies": {
    "@1gr14/route0": "^0.1.0",
    "@point0/core": "^0.1.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "wouter": "^3.10.0"
  },
  "devDependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@1gr14/route0": "^0.1.0",
    "@point0/core": "^0.1.6",
    "wouter": "^3.10.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^20.0.0",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
