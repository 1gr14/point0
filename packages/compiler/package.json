{
  "name": "@point0/compiler",
  "version": "0.1.0",
  "license": "MIT",
  "author": {
    "name": "Sergei Dmitriev",
    "url": "https://1gr14.dev"
  },
  "homepage": "https://github.com/1gr14/point0#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/1gr14/point0.git",
    "directory": "packages/compiler"
  },
  "bugs": {
    "url": "https://github.com/1gr14/point0/issues"
  },
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "": [
        "./dist/index.d.ts"
      ],
      "plugin/vite": [
        "./dist/plugin/vite.d.ts"
      ],
      "plugin/bun": [
        "./dist/plugin/bun.d.ts"
      ],
      "plugin/bun-static": [
        "./dist/plugin/bun-static.d.ts"
      ],
      "plugin/babel": [
        "./dist/plugin/babel.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./plugin/vite": {
      "types": "./dist/plugin/vite.d.ts",
      "import": "./dist/plugin/vite.js"
    },
    "./plugin/bun": {
      "types": "./dist/plugin/bun.d.ts",
      "import": "./dist/plugin/bun.js"
    },
    "./plugin/bun-static": {
      "types": "./dist/plugin/bun-static.d.ts",
      "import": "./dist/plugin/bun-static.js"
    },
    "./plugin/babel": {
      "types": "./dist/plugin/babel.d.ts",
      "import": "./dist/plugin/babel.js"
    }
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "test": "bun test ./tests",
    "test:watch": "bun test --watch ./tests",
    "types": "tsc --noEmit -p tsconfig.build.json",
    "typesgo": "tsgo --noEmit -p tsconfig.build.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "pack:dist": "rimraf ../../packages-dist-npm && bun ../../scripts/transform-package-for-publish.ts && mkdir -p ../../packages-dist-npm/compiler && npm pack --pack-destination ../../packages-dist-npm/compiler --silent && (cd ../../packages-dist-npm/compiler && tar -xzf *.tgz && cp -r package/* . && rm -rf package && rm *.tgz) && bun ../../scripts/restore-package.ts",
    "prepublishOnly": "bun ../../scripts/transform-package-for-publish.ts",
    "postpublish": "bun ../../scripts/restore-package.ts"
  },
  "dependencies": {
    "@svgr/core": "catalog:",
    "@svgr/plugin-jsx": "catalog:",
    "@babel/core": "^7.29.7",
    "@babel/generator": "^7.29.7",
    "@babel/parser": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@babel/traverse": "^7.29.7",
    "@babel/types": "^7.29.7",
    "@jridgewell/remapping": "^2.3.5",
    "@mdx-js/mdx": "^3.1.1",
    "babel-plugin-minify-dead-code-elimination": "^0.5.2",
    "babel-plugin-minify-guarded-expressions": "^0.4.4",
    "minimatch": "^10.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-mdx-frontmatter": "^5.2.0"
  },
  "peerDependencies": {
    "@1gr14/route0": "catalog:",
    "@point0/core": "workspace:*",
    "@1gr14/flat": "catalog:",
    "typescript": "*"
  },
  "devDependencies": {
    "@1gr14/flat": "catalog:",
    "@point0/engine": "workspace:*",
    "@types/babel__core": "^7.20.5",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__traverse": "^7.28.0",
    "@types/bun": "catalog:",
    "@types/node": "^20.0.0",
    "babel-plugin-react-compiler": "catalog:",
    "dedent": "^1.7.1",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
