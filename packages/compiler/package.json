{
  "name": "@point0/compiler",
  "version": "0.1.0",
  "homepage": "https://github.com/devp0nt/point0#readme",
  "bugs": {
    "url": "https://github.com/devp0nt/point0/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Sergei Dmitriev",
    "url": "https://p0nt.dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devp0nt/point0.git",
    "directory": "packages/compiler"
  },
  "files": [
    "dist/**/*",
    "src/**/*",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./plugin/vite": {
      "types": "./dist/plugin/vite.d.ts",
      "import": "./dist/plugin/vite.js"
    },
    "./plugin/bun": {
      "types": "./dist/plugin/bun.d.ts",
      "import": "./dist/plugin/bun.js"
    },
    "./plugin/bun-static": {
      "types": "./dist/plugin/bun-static.d.ts",
      "import": "./dist/plugin/bun-static.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "test": "bun test ./tests",
    "test:watch": "bun test --watch ./tests",
    "types": "tsc --noEmit -p tsconfig.build.json",
    "typesgo": "tsgo --noEmit -p tsconfig.build.json",
    "lint": "oxlint . --type-aware",
    "format": "oxfmt . --write",
    "pack:dist": "rimraf ../../packages-dist-npm && bun ../../scripts/transform-package-for-publish.ts && mkdir -p ../../packages-dist-npm/wouter && npm pack --pack-destination ../../packages-dist-npm/wouter --silent && (cd ../../packages-dist-npm/wouter && tar -xzf *.tgz && cp -r package/* . && rm -rf package && rm *.tgz) && bun ../../scripts/restore-package.ts",
    "prepublishOnly": "bun ../../scripts/transform-package-for-publish.ts",
    "postpublish": "bun ../../scripts/restore-package.ts"
  },
  "dependencies": {
    "@babel/generator": "^7.28.5",
    "@babel/parser": "^7.28.5",
    "@babel/traverse": "^7.28.5",
    "@babel/types": "^7.28.5"
  },
  "devDependencies": {
    "@point0/engine": "workspace:*",
    "@types/babel__traverse": "^7.28.0",
    "@types/bun": "^1.2.22",
    "@types/node": "^20.0.0",
    "dedent": "^1.7.1",
    "esbuild-fix-imports-plugin": "^1.0.22",
    "tsup": "^8.0.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@devp0nt/route0": "catalog:",
    "@point0/core": "workspace:*",
    "typescript": "*"
  }
}
