{
  "name": "@point0/compiler",
  "version": "0.1.0",
  "license": "MIT",
  "author": {
    "name": "Sergei Dmitriev",
    "url": "https://p0nt.dev"
  },
  "homepage": "https://github.com/devp0nt/point0#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devp0nt/point0.git",
    "directory": "packages/compiler"
  },
  "bugs": {
    "url": "https://github.com/devp0nt/point0/issues"
  },
  "type": "module",
  "types": "./dist/esm/index.d.ts",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "typesVersions": {
    "*": {
      "": [
        "./dist/esm/index.d.ts"
      ],
      "plugin/vite": [
        "./dist/esm/plugin/vite.d.ts"
      ],
      "plugin/bun": [
        "./dist/esm/plugin/bun.d.ts"
      ],
      "plugin/bun-static": [
        "./dist/esm/plugin/bun-static.d.ts"
      ],
      "plugin/babel": [
        "./dist/esm/plugin/babel.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "require": "./dist/cjs/index.cjs",
      "import": "./dist/esm/index.js"
    },
    "./plugin/vite": {
      "types": "./dist/esm/plugin/vite.d.ts",
      "require": "./dist/cjs/plugin/vite.cjs",
      "import": "./dist/esm/plugin/vite.js"
    },
    "./plugin/bun": {
      "types": "./dist/esm/plugin/bun.d.ts",
      "require": "./dist/cjs/plugin/bun.cjs",
      "import": "./dist/esm/plugin/bun.js"
    },
    "./plugin/bun-static": {
      "types": "./dist/esm/plugin/bun-static.d.ts",
      "require": "./dist/cjs/plugin/bun-static.cjs",
      "import": "./dist/esm/plugin/bun-static.js"
    },
    "./plugin/babel": {
      "types": "./dist/esm/plugin/babel.d.ts",
      "require": "./dist/cjs/plugin/babel.cjs",
      "import": "./dist/esm/plugin/babel.js"
    }
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "test": "bun test ./tests",
    "test:watch": "bun test --watch ./tests",
    "types": "tsc --noEmit -p tsconfig.build.json",
    "typesgo": "tsgo --noEmit -p tsconfig.build.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "pack:dist": "rimraf ../../packages-dist-npm && bun ../../scripts/transform-package-for-publish.ts && mkdir -p ../../packages-dist-npm/wouter && npm pack --pack-destination ../../packages-dist-npm/wouter --silent && (cd ../../packages-dist-npm/wouter && tar -xzf *.tgz && cp -r package/* . && rm -rf package && rm *.tgz) && bun ../../scripts/restore-package.ts",
    "prepublishOnly": "bun ../../scripts/transform-package-for-publish.ts",
    "postpublish": "bun ../../scripts/restore-package.ts"
  },
  "dependencies": {
    "@babel/core": "^7.29.0",
    "@babel/generator": "^7.29.0",
    "@babel/parser": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@mdx-js/mdx": "^3.1.1",
    "babel-plugin-minify-dead-code-elimination": "^0.5.2",
    "babel-plugin-minify-guarded-expressions": "^0.4.4",
    "remark-frontmatter": "^5.0.0",
    "minimatch": "^10.0.1"
  },
  "peerDependencies": {
    "@devp0nt/route0": "catalog:",
    "@point0/core": "workspace:*",
    "typescript": "*"
  },
  "devDependencies": {
    "@point0/engine": "workspace:*",
    "@types/babel__traverse": "^7.28.0",
    "@types/bun": "^1.2.22",
    "@types/node": "^20.0.0",
    "dedent": "^1.7.1",
    "esbuild-fix-imports-plugin": "^1.0.22",
    "tsup": "^8.0.0",
    "typescript": "catalog:"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
