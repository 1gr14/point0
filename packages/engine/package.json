{
  "name": "@point0/engine",
  "version": "0.1.0",
  "license": "MIT",
  "author": {
    "name": "Sergei Dmitriev",
    "url": "https://p0nt.dev"
  },
  "homepage": "https://github.com/devp0nt/point0#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devp0nt/point0.git",
    "directory": "packages/engine"
  },
  "bugs": {
    "url": "https://github.com/devp0nt/point0/issues"
  },
  "type": "module",
  "bin": {
    "point0": "./dist/cli.js"
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    },
    "./error": {
      "types": "./dist/error.d.ts",
      "import": "./dist/error.js"
    },
    "./fetch": {
      "types": "./dist/fetch.d.ts",
      "import": "./dist/fetch.js"
    },
    "./render": {
      "types": "./dist/render.d.ts",
      "import": "./dist/render.js"
    },
    "./generator": {
      "types": "./dist/generator.d.ts",
      "import": "./dist/generator.js"
    },
    "./publicdir": {
      "types": "./dist/publicdir.d.ts",
      "import": "./dist/publicdir.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "import": "./dist/utils.js"
    },
    "./executor": {
      "types": "./dist/executor.d.ts",
      "import": "./dist/executor.js"
    },
    "./all-points-managers": {
      "types": "./dist/all-points-managers.d.ts",
      "import": "./dist/all-points-managers.js"
    },
    "./kill-port": {
      "types": "./dist/kill-port.d.ts",
      "import": "./dist/kill-port.js"
    }
  },
  "files": [
    "dist/**/*",
    "src/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "test": "bun test ./tests",
    "test:watch": "bun test --watch ./tests",
    "types": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "pack:dist": "rimraf ../../packages-dist-npm && bun ../../scripts/transform-package-for-publish.ts && mkdir -p ../../packages-dist-npm/engine && npm pack --pack-destination ../../packages-dist-npm/engine --silent && (cd ../../packages-dist-npm/engine && tar -xzf *.tgz && cp -r package/* . && rm -rf package && rm *.tgz) && bun ../../scripts/restore-package.ts",
    "prepublishOnly": "bun ../../scripts/transform-package-for-publish.ts",
    "postpublish": "bun ../../scripts/restore-package.ts"
  },
  "dependencies": {
    "@parcel/watcher": "^2.5.1",
    "commander": "^14.0.2",
    "fast-glob": "^3.3.2",
    "fetch-cookie": "^3.2.0",
    "fetch-to-node": "^2.1.0",
    "magic-string": "^0.30.21",
    "minimatch": "^10.0.1",
    "p-retry": "^7.1.1",
    "qs": "^6.14.0",
    "tough-cookie": "^6.0.0"
  },
  "peerDependencies": {
    "@point0/core": "workspace:*",
    "@point0/env": "workspace:*",
    "@point0/compiler": "workspace:*",
    "react": "catalog:",
    "react-dom": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@devp0nt/error0": "catalog:",
    "@devp0nt/route0": "catalog:",
    "@unhead/react": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "^1.2.22",
    "@types/lodash": "^4.17.20",
    "@types/minimatch": "^6.0.0",
    "@types/node": "^20.0.0",
    "@types/qs": "^6.14.0",
    "@vitejs/plugin-react": "^5.1.2",
    "esbuild-fix-imports-plugin": "^1.0.22",
    "lodash": "^4.17.21",
    "playwright": "^1.57.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vite": "^7.3.1",
    "vite-plugin-svgr": "^4.5.0",
    "vite-tsconfig-paths": "^6.0.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
