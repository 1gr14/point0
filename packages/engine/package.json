{
  "name": "@point0/engine",
  "version": "0.1.0-next.1",
  "license": "MIT",
  "author": {
    "name": "Sergei Dmitriev",
    "url": "https://1gr14.dev"
  },
  "homepage": "https://github.com/1gr14/point0#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/1gr14/point0.git",
    "directory": "packages/engine"
  },
  "bugs": {
    "url": "https://github.com/1gr14/point0/issues"
  },
  "type": "module",
  "sideEffects": false,
  "engines": {
    "bun": ">=1.3.14"
  },
  "bin": {
    "point0": "dist/cli.js",
    "point0-project-mcp": "dist/mcp.js"
  },
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "": [
        "./dist/index.d.ts"
      ],
      "analyzer": [
        "./dist/analyzer.d.ts"
      ],
      "cli": [
        "./dist/cli.d.ts"
      ],
      "client": [
        "./dist/client.d.ts"
      ],
      "config": [
        "./dist/config.d.ts"
      ],
      "executor": [
        "./dist/executor.d.ts"
      ],
      "fake-client": [
        "./dist/fake-client.d.ts"
      ],
      "fetcher": [
        "./dist/fetcher.d.ts"
      ],
      "generator": [
        "./dist/generator.d.ts"
      ],
      "mcp": [
        "./dist/mcp.d.ts"
      ],
      "port": [
        "./dist/port.d.ts"
      ],
      "meta": [
        "./dist/meta.d.ts"
      ],
      "publicdir": [
        "./dist/publicdir.d.ts"
      ],
      "render": [
        "./dist/render.d.ts"
      ],
      "server-points": [
        "./dist/server-points.d.ts"
      ],
      "server": [
        "./dist/server.d.ts"
      ],
      "utils": [
        "./dist/utils.d.ts"
      ],
      "watcher": [
        "./dist/watcher.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./analyzer": {
      "types": "./dist/analyzer.d.ts",
      "import": "./dist/analyzer.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    },
    "./executor": {
      "types": "./dist/executor.d.ts",
      "import": "./dist/executor.js"
    },
    "./fake-client": {
      "types": "./dist/fake-client.d.ts",
      "import": "./dist/fake-client.js"
    },
    "./fetcher": {
      "types": "./dist/fetcher.d.ts",
      "import": "./dist/fetcher.js"
    },
    "./generator": {
      "types": "./dist/generator.d.ts",
      "import": "./dist/generator.js"
    },
    "./port": {
      "types": "./dist/port.d.ts",
      "import": "./dist/port.js"
    },
    "./meta": {
      "types": "./dist/meta.d.ts",
      "import": "./dist/meta.js"
    },
    "./publicdir": {
      "types": "./dist/publicdir.d.ts",
      "import": "./dist/publicdir.js"
    },
    "./render": {
      "types": "./dist/render.d.ts",
      "import": "./dist/render.js"
    },
    "./server-points": {
      "types": "./dist/server-points.d.ts",
      "import": "./dist/server-points.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "import": "./dist/utils.js"
    },
    "./watcher": {
      "types": "./dist/watcher.d.ts",
      "import": "./dist/watcher.js"
    }
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "test": "bun test ./tests",
    "test:watch": "bun test --watch ./tests",
    "types": "tsgo --noEmit -p tsconfig.build.json",
    "types:6": "tsc --noEmit -p tsconfig.build.json",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@jridgewell/remapping": "^2.3.5",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@parcel/watcher": "^2.5.1",
    "commander": "^15.0.0",
    "devalue": "^5.8.1",
    "fast-glob": "^3.3.2",
    "fetch-cookie": "^3.2.0",
    "fetch-to-node": "^2.1.0",
    "minimatch": "^10.0.1",
    "source-map-support": "^0.5.21",
    "tough-cookie": "^6.0.0",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
