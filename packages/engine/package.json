    "@unhead/react": "^3.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/source-map-support": "^0.5.10",
    "superjson": "^2.2.6",
    "@1gr14/error0": "^0.4.0",
    "@1gr14/flat": "^0.1.0",
    "@1gr14/route0": "^0.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/react": "^19.2.16",
    "@tanstack/query-core": "^5.101.0",
    "safe-stable-stringify": "^2.5.0",
    "@point0/docs": "^0.1.0-next.1",
    "@testing-library/react": "^16.3.1",
    "@types/bun": "^1.3.14",
    "@types/minimatch": "^6.0.0",
    "@types/node": "^20.0.0",
    "happy-dom": "20.3.0",
    "playwright": "^1.60.0",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "@vitejs/plugin-react": "^6.0.2",
    "vite": "^8.0.16",
    "vite-plugin-svgr": "^5.2.0",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
