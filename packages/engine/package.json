{
  "name": "@point0/engine",
  "version": "0.1.0",
  "license": "MIT",
  "author": {
    "name": "Sergei Dmitriev",
    "url": "https://p0nt.dev"
  },
  "homepage": "https://github.com/devp0nt/point0#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devp0nt/point0.git",
    "directory": "packages/engine"
  },
  "bugs": {
    "url": "https://github.com/devp0nt/point0/issues"
  },
  "type": "module",
  "bin": {
    "point0": "./dist/bin.js"
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./client-bun-dev-server": {
      "types": "./dist/client-bun-dev-server.d.ts",
      "import": "./dist/client-bun-dev-server.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    },
    "./error": {
      "types": "./dist/error.d.ts",
      "import": "./dist/error.js"
    },
    "./fetch": {
      "types": "./dist/fetch.d.ts",
      "import": "./dist/fetch.js"
    },
    "./generator": {
      "types": "./dist/generator.d.ts",
      "import": "./dist/generator.js"
    },
    "./render": {
      "types": "./dist/render.d.ts",
      "import": "./dist/render.js"
    },
    "./pruner": {
      "types": "./dist/pruner.d.ts",
      "import": "./dist/pruner.js"
    },
    "./publicdir": {
      "types": "./dist/publicdir.d.ts",
      "import": "./dist/publicdir.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "import": "./dist/utils.js"
    },
    "./walker": {
      "types": "./dist/walker.d.ts",
      "import": "./dist/walker.js"
    }
  },
  "files": [
    "dist/**/*",
    "src/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "test": "bun test ./tests",
    "test:watch": "bun test --watch ./tests",
    "types": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@babel/parser": "^7.28.5",
    "@babel/traverse": "^7.28.5",
    "@parcel/watcher": "^2.5.1",
    "commander": "^14.0.2",
    "fast-glob": "^3.3.2",
    "magic-string": "^0.30.21",
    "minimatch": "^10.0.1",
    "qs": "^6.14.0"
  },
  "peerDependencies": {
    "@point0/core": "workspace:*",
    "react": "catalog:",
    "react-dom": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@devp0nt/error0": "catalog:",
    "@devp0nt/route0": "catalog:",
    "@unhead/react": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.28.0",
    "@types/bun": "^1.2.22",
    "@types/minimatch": "^6.0.0",
    "@types/node": "^20.0.0",
    "@types/qs": "^6.14.0",
    "esbuild-fix-imports-plugin": "^1.0.22",
    "lodash": "^4.17.21",
    "@types/lodash": "^4.17.20",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
