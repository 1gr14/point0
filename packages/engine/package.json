{
  "name": "@point0/engine",
  "version": "0.1.0",
  "license": "MIT",
  "author": {
    "name": "Sergei Dmitriev",
    "url": "https://p0nt.dev"
  },
  "homepage": "https://github.com/devp0nt/point0#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devp0nt/point0.git",
    "directory": "packages/engine"
  },
  "bugs": {
    "url": "https://github.com/devp0nt/point0/issues"
  },
  "type": "module",
  "bin": {
    "point0": "./dist/esm/cli.js",
    "point0-mcp": "./dist/esm/mcp.js"
  },
  "types": "./dist/esm/index.d.ts",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "typesVersions": {
    "*": {
      "": [
        "./dist/esm/index.d.ts"
      ],
      "analyzer": [
        "./dist/esm/analyzer.d.ts"
      ],
      "cli": [
        "./dist/esm/cli.d.ts"
      ],
      "client": [
        "./dist/esm/client.d.ts"
      ],
      "config": [
        "./dist/esm/config.d.ts"
      ],
      "executor": [
        "./dist/esm/executor.d.ts"
      ],
      "fake-client": [
        "./dist/esm/fake-client.d.ts"
      ],
      "fetcher": [
        "./dist/esm/fetcher.d.ts"
      ],
      "generator": [
        "./dist/esm/generator.d.ts"
      ],
      "mcp": [
        "./dist/esm/mcp.d.ts"
      ],
      "port": [
        "./dist/esm/port.d.ts"
      ],
      "meta": [
        "./dist/esm/meta.d.ts"
      ],
      "publicdir": [
        "./dist/esm/publicdir.d.ts"
      ],
      "render": [
        "./dist/esm/render.d.ts"
      ],
      "server-points": [
        "./dist/esm/server-points.d.ts"
      ],
      "server": [
        "./dist/esm/server.d.ts"
      ],
      "utils": [
        "./dist/esm/utils.d.ts"
      ],
      "watcher": [
        "./dist/esm/watcher.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "require": "./dist/cjs/index.cjs",
      "import": "./dist/esm/index.js"
    },
    "./analyzer": {
      "types": "./dist/esm/analyzer.d.ts",
      "require": "./dist/cjs/analyzer.cjs",
      "import": "./dist/esm/analyzer.js"
    },
    "./client": {
      "types": "./dist/esm/client.d.ts",
      "require": "./dist/cjs/client.cjs",
      "import": "./dist/esm/client.js"
    },
    "./config": {
      "types": "./dist/esm/config.d.ts",
      "require": "./dist/cjs/config.cjs",
      "import": "./dist/esm/config.js"
    },
    "./executor": {
      "types": "./dist/esm/executor.d.ts",
      "require": "./dist/cjs/executor.cjs",
      "import": "./dist/esm/executor.js"
    },
    "./fake-client": {
      "types": "./dist/esm/fake-client.d.ts",
      "require": "./dist/cjs/fake-client.cjs",
      "import": "./dist/esm/fake-client.js"
    },
    "./fetcher": {
      "types": "./dist/esm/fetcher.d.ts",
      "require": "./dist/cjs/fetcher.cjs",
      "import": "./dist/esm/fetcher.js"
    },
    "./generator": {
      "types": "./dist/esm/generator.d.ts",
      "require": "./dist/cjs/generator.cjs",
      "import": "./dist/esm/generator.js"
    },
    "./port": {
      "types": "./dist/esm/port.d.ts",
      "require": "./dist/cjs/port.cjs",
      "import": "./dist/esm/port.js"
    },
    "./meta": {
      "types": "./dist/esm/meta.d.ts",
      "require": "./dist/cjs/meta.cjs",
      "import": "./dist/esm/meta.js"
    },
    "./publicdir": {
      "types": "./dist/esm/publicdir.d.ts",
      "require": "./dist/cjs/publicdir.cjs",
      "import": "./dist/esm/publicdir.js"
    },
    "./render": {
      "types": "./dist/esm/render.d.ts",
      "require": "./dist/cjs/render.cjs",
      "import": "./dist/esm/render.js"
    },
    "./server-points": {
      "types": "./dist/esm/server-points.d.ts",
      "require": "./dist/cjs/server-points.cjs",
      "import": "./dist/esm/server-points.js"
    },
    "./server": {
      "types": "./dist/esm/server.d.ts",
      "require": "./dist/cjs/server.cjs",
      "import": "./dist/esm/server.js"
    },
    "./utils": {
      "types": "./dist/esm/utils.d.ts",
      "require": "./dist/cjs/utils.cjs",
      "import": "./dist/esm/utils.js"
    },
    "./watcher": {
      "types": "./dist/esm/watcher.d.ts",
      "require": "./dist/cjs/watcher.cjs",
      "import": "./dist/esm/watcher.js"
    }
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "test": "bun test ./tests",
    "test:watch": "bun test --watch ./tests",
    "types": "tsc --noEmit -p tsconfig.build.json",
    "typesgo": "tsgo --noEmit -p tsconfig.build.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "pack:dist": "rimraf ../../packages-dist-npm && bun ../../scripts/transform-package-for-publish.ts && mkdir -p ../../packages-dist-npm/engine && npm pack --pack-destination ../../packages-dist-npm/engine --silent && (cd ../../packages-dist-npm/engine && tar -xzf *.tgz && cp -r package/* . && rm -rf package && rm *.tgz) && bun ../../scripts/restore-package.ts",
    "prepublishOnly": "bun ../../scripts/transform-package-for-publish.ts",
    "postpublish": "bun ../../scripts/restore-package.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@parcel/watcher": "^2.5.1",
    "commander": "^14.0.2",
    "devalue": "^5.6.2",
    "fast-glob": "^3.3.2",
    "fetch-cookie": "^3.2.0",
    "fetch-to-node": "^2.1.0",
    "magic-string": "^0.30.21",
    "minimatch": "^10.0.1",
    "p-retry": "^7.1.1",
    "qs": "^6.14.0",
    "tough-cookie": "^6.0.0",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "@devp0nt/route0": "catalog:",
    "@point0/compiler": "workspace:*",
    "@point0/core": "workspace:*",
    "@tanstack/react-query": "catalog:",
    "@unhead/react": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@devp0nt/error0": "catalog:",
    "@point0/cookies-store": "workspace:*",
    "@testing-library/react": "^16.3.1",
    "@types/bun": "^1.2.22",
    "@types/lodash": "^4.17.20",
    "@types/minimatch": "^6.0.0",
    "@types/node": "^20.0.0",
    "@types/qs": "^6.14.0",
    "@vitejs/plugin-react": "^5.1.2",
    "esbuild-fix-imports-plugin": "^1.0.22",
    "happy-dom": "20.3.0",
    "lodash": "^4.17.21",
    "playwright": "^1.57.0",
    "tsup": "^8.0.0",
    "typescript": "catalog:",
    "vite": "^7.3.1",
    "vite-plugin-svgr": "^4.5.0",
    "vite-tsconfig-paths": "^6.0.4"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
