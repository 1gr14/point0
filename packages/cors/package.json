{
  "name": "@point0/cors",
  "version": "0.2.6",
  "license": "MIT",
  "author": {
    "name": "Sergei Dmitriev",
    "url": "https://1gr14.dev"
  },
  "homepage": "https://github.com/1gr14/point0#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/1gr14/point0.git",
    "directory": "packages/cors"
  },
  "bugs": {
    "url": "https://github.com/1gr14/point0/issues"
  },
  "type": "module",
  "engines": {
    "bun": ">=1.3.14"
  },
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "": [
        "./dist/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "test": "bun test ./tests",
    "test:watch": "bun test --watch ./tests",
    "types": "tsgo --noEmit -p tsconfig.build.json",
    "types:6": "tsc --noEmit -p tsconfig.build.json",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "peerDependencies": {
    "@point0/core": "^0.2.6",
    "@point0/engine": "^0.2.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^20.0.0",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
