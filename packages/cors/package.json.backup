{
  "name": "@point0/cors",
  "version": "0.1.0",
  "license": "MIT",
  "author": {
    "name": "Sergei Dmitriev",
    "url": "https://p0nt.dev"
  },
  "homepage": "https://github.com/devp0nt/point0#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devp0nt/point0.git",
    "directory": "packages/cors"
  },
  "bugs": {
    "url": "https://github.com/devp0nt/point0/issues"
  },
  "type": "module",
  "types": "./dist/esm/index.d.ts",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "typesVersions": {
    "*": {
      "": [
        "./dist/esm/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "require": "./dist/cjs/index.cjs",
      "import": "./dist/esm/index.js"
    }
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "test": "bun test ./tests",
    "test:watch": "bun test --watch ./tests",
    "types": "tsc --noEmit -p tsconfig.build.json",
    "typesgo": "tsgo --noEmit -p tsconfig.build.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "pack:dist": "rimraf ../../packages-dist-npm && bun ../../scripts/transform-package-for-publish.ts && mkdir -p ../../packages-dist-npm/cors && npm pack --pack-destination ../../packages-dist-npm/cors --silent && (cd ../../packages-dist-npm/cors && tar -xzf *.tgz && cp -r package/* . && rm -rf package && rm *.tgz) && bun ../../scripts/restore-package.ts",
    "prepublishOnly": "bun ../../scripts/transform-package-for-publish.ts",
    "postpublish": "bun ../../scripts/restore-package.ts"
  },
  "peerDependencies": {
    "@point0/core": "workspace:*",
    "@point0/engine": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1.2.22",
    "@types/node": "^20.0.0",
    "esbuild-fix-imports-plugin": "^1.0.22",
    "tsup": "^8.0.0",
    "typescript": "catalog:"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
