{
  "name": "@point0/core",
  "version": "0.1.0",
  "license": "MIT",
  "author": {
    "name": "Sergei Dmitriev",
    "url": "https://p0nt.dev"
  },
  "homepage": "https://github.com/devp0nt/point0#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devp0nt/point0.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/devp0nt/point0/issues"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./mount": {
      "types": "./dist/mount.d.ts",
      "import": "./dist/mount.js"
    },
    "./points": {
      "types": "./dist/points.d.ts",
      "import": "./dist/points.js"
    },
    "./router": {
      "types": "./dist/router.d.ts",
      "import": "./dist/router.js"
    },
    "./eversion": {
      "types": "./dist/eversion.d.ts",
      "import": "./dist/eversion.js"
    },
    "./eversion-store": {
      "types": "./dist/eversion-store.d.ts",
      "import": "./dist/eversion-store.js"
    },
    "./eversion-run": {
      "types": "./dist/eversion-run.d.ts",
      "import": "./dist/eversion-run.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./unhead": {
      "types": "./dist/unhead.d.ts",
      "import": "./dist/unhead.js"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "import": "./dist/utils.js"
    },
    "./client-server": {
      "types": "./dist/client-server.d.ts",
      "import": "./dist/client-server.js"
    }
  },
  "files": [
    "dist/**/*",
    "src/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "test": "bun test ./tests",
    "test:watch": "bun test --watch ./tests",
    "types": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "react-ssr-prepass": "^1.6.0",
    "safe-stable-stringify": "^2.5.0",
    "superjson": "^2.2.5",
    "use-context-selector": "^2.0.0"
  },
  "peerDependencies": {
    "react": "catalog:",
    "react-dom": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@devp0nt/error0": "catalog:",
    "@devp0nt/route0": "catalog:",
    "@unhead/react": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "^1.2.22",
    "@types/node": "^20.0.0",
    "esbuild-fix-imports-plugin": "^1.0.22",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
