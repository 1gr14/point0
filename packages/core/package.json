{
  "name": "@point0/core",
  "version": "0.1.0",
  "license": "MIT",
  "author": {
    "name": "Sergei Dmitriev",
    "url": "https://p0nt.dev"
  },
  "homepage": "https://github.com/devp0nt/point0#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devp0nt/point0.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/devp0nt/point0/issues"
  },
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "": [
        "./dist/index.d.ts"
      ],
      "client-only": [
        "./dist/client-only.d.ts"
      ],
      "server-only": [
        "./dist/server-only.d.ts"
      ],
      "cold": [
        "./dist/cold.d.ts"
      ],
      "virtual": [
        "./dist/virtual.d.ts"
      ],
      "effects": [
        "./dist/effects.d.ts"
      ],
      "request0": [
        "./dist/request0.d.ts"
      ],
      "ssr-store": [
        "./dist/ssr-store.d.ts"
      ],
      "cookie-store": [
        "./dist/cookie-store.d.ts"
      ],
      "navigation": [
        "./dist/navigation.d.ts"
      ],
      "unhead": [
        "./dist/unhead.d.ts"
      ],
      "schema/utils": [
        "./dist/schema/utils.d.ts"
      ],
      "schema/arktype": [
        "./dist/schema/arktype.d.ts"
      ],
      "schema/typebox": [
        "./dist/schema/typebox.d.ts"
      ],
      "schema/valibot": [
        "./dist/schema/valibot.d.ts"
      ],
      "schema/yup": [
        "./dist/schema/yup.d.ts"
      ],
      "schema/zod": [
        "./dist/schema/zod.d.ts"
      ],
      "schema/superstruct": [
        "./dist/schema/superstruct.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client-only": {
      "types": "./dist/client-only.d.ts",
      "import": "./dist/client-only.js"
    },
    "./server-only": {
      "types": "./dist/server-only.d.ts",
      "import": "./dist/server-only.js"
    },
    "./cold": {
      "types": "./dist/cold.d.ts",
      "import": "./dist/cold.js"
    },
    "./virtual": {
      "types": "./dist/virtual.d.ts",
      "import": "./dist/virtual.js"
    },
    "./effects": {
      "types": "./dist/effects.d.ts",
      "import": "./dist/effects.js"
    },
    "./request0": {
      "types": "./dist/request0.d.ts",
      "import": "./dist/request0.js"
    },
    "./ssr-store": {
      "types": "./dist/ssr-store.d.ts",
      "import": "./dist/ssr-store.js"
    },
    "./cookie-store": {
      "types": "./dist/cookie-store.d.ts",
      "import": "./dist/cookie-store.js"
    },
    "./navigation": {
      "types": "./dist/navigation.d.ts",
      "import": "./dist/navigation.js"
    },
    "./unhead": {
      "types": "./dist/unhead.d.ts",
      "import": "./dist/unhead.js"
    },
    "./schema/utils": {
      "types": "./dist/schema/utils.d.ts",
      "import": "./dist/schema/utils.js"
    },
    "./schema/arktype": {
      "types": "./dist/schema/arktype.d.ts",
      "import": "./dist/schema/arktype.js"
    },
    "./schema/typebox": {
      "types": "./dist/schema/typebox.d.ts",
      "import": "./dist/schema/typebox.js"
    },
    "./schema/valibot": {
      "types": "./dist/schema/valibot.d.ts",
      "import": "./dist/schema/valibot.js"
    },
    "./schema/yup": {
      "types": "./dist/schema/yup.d.ts",
      "import": "./dist/schema/yup.js"
    },
    "./schema/zod": {
      "types": "./dist/schema/zod.d.ts",
      "import": "./dist/schema/zod.js"
    },
    "./schema/superstruct": {
      "types": "./dist/schema/superstruct.d.ts",
      "import": "./dist/schema/superstruct.js"
    }
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "test": "bun test ./tests",
    "test:watch": "bun test --watch ./tests",
    "types": "tsc --noEmit -p tsconfig.build.json",
    "typesgo": "tsgo --noEmit -p tsconfig.build.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "pack:dist": "rimraf ../../packages-dist-npm && bun ../../scripts/transform-package-for-publish.ts && mkdir -p ../../packages-dist-npm/core && npm pack --pack-destination ../../packages-dist-npm/core --silent && (cd ../../packages-dist-npm/core && tar -xzf *.tgz && cp -r package/* . && rm -rf package && rm *.tgz) && bun ../../scripts/restore-package.ts",
    "prepublishOnly": "bun ../../scripts/transform-package-for-publish.ts",
    "postpublish": "bun ../../scripts/restore-package.ts"
  },
  "dependencies": {
    "@standard-schema/spec": "^1.1.0",
    "safe-stable-stringify": "catalog:",
    "use-context-selector": "^2.0.0"
  },
  "peerDependencies": {
    "@devp0nt/flat0": "catalog:",
    "@devp0nt/route0": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@unhead/react": "catalog:",
    "unhead": "catalog:",
    "openapi-types": "catalog:",
    "react": "catalog:"
  },
  "devDependencies": {
    "@devp0nt/flat0": "catalog:",
    "@devp0nt/route0": "catalog:",
    "@sinclair/typebox": "catalog:",
    "@types/bun": "catalog:",
    "@types/node": "^20.0.0",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@unhead/react": "catalog:",
    "@valibot/to-json-schema": "^1.7.0",
    "arktype": "catalog:",
    "react": "catalog:",
    "superjson": "^2.2.6",
    "superstruct": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "unhead": "catalog:",
    "valibot": "catalog:",
    "yup": "catalog:",
    "zod": "catalog:"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
