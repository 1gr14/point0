{
  "name": "@point0/core",
  "version": "0.1.0",
  "license": "MIT",
  "author": {
    "name": "Sergei Dmitriev",
    "url": "https://p0nt.dev"
  },
  "homepage": "https://github.com/devp0nt/point0#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devp0nt/point0.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/devp0nt/point0/issues"
  },
  "type": "module",
  "types": "./dist/esm/index.d.ts",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "typesVersions": {
    "*": {
      "": [
        "./dist/esm/index.d.ts"
      ],
      "client-only": [
        "./dist/esm/client-only.d.ts"
      ],
      "server-only": [
        "./dist/esm/server-only.d.ts"
      ],
      "virtual": [
        "./dist/esm/virtual.d.ts"
      ],
      "effects": [
        "./dist/esm/effects.d.ts"
      ],
      "request0": [
        "./dist/esm/request0.d.ts"
      ],
      "navigation": [
        "./dist/esm/navigation.d.ts"
      ],
      "unhead": [
        "./dist/esm/unhead.d.ts"
      ],
      "schema/utils": [
        "./dist/esm/schema/utils.d.ts"
      ],
      "schema/arktype": [
        "./dist/esm/schema/arktype.d.ts"
      ],
      "schema/typebox": [
        "./dist/esm/schema/typebox.d.ts"
      ],
      "schema/valibot": [
        "./dist/esm/schema/valibot.d.ts"
      ],
      "schema/yup": [
        "./dist/esm/schema/yup.d.ts"
      ],
      "schema/zod": [
        "./dist/esm/schema/zod.d.ts"
      ],
      "schema/superstruct": [
        "./dist/esm/schema/superstruct.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "require": "./dist/cjs/index.cjs",
      "import": "./dist/esm/index.js"
    },
    "./client-only": {
      "types": "./dist/esm/client-only.d.ts",
      "require": "./dist/cjs/client-only.cjs",
      "import": "./dist/esm/client-only.js"
    },
    "./server-only": {
      "types": "./dist/esm/server-only.d.ts",
      "require": "./dist/cjs/server-only.cjs",
      "import": "./dist/esm/server-only.js"
    },
    "./virtual": {
      "types": "./dist/esm/virtual.d.ts",
      "require": "./dist/cjs/virtual.cjs",
      "import": "./dist/esm/virtual.js"
    },
    "./effects": {
      "types": "./dist/esm/effects.d.ts",
      "require": "./dist/cjs/effects.cjs",
      "import": "./dist/esm/effects.js"
    },
    "./request0": {
      "types": "./dist/esm/request0.d.ts",
      "require": "./dist/cjs/request0.cjs",
      "import": "./dist/esm/request0.js"
    },
    "./navigation": {
      "types": "./dist/esm/navigation.d.ts",
      "require": "./dist/cjs/navigation.cjs",
      "import": "./dist/esm/navigation.js"
    },
    "./unhead": {
      "types": "./dist/esm/unhead.d.ts",
      "require": "./dist/cjs/unhead.cjs",
      "import": "./dist/esm/unhead.js"
    },
    "./schema/utils": {
      "types": "./dist/esm/schema/utils.d.ts",
      "require": "./dist/cjs/schema/utils.cjs",
      "import": "./dist/esm/schema/utils.js"
    },
    "./schema/arktype": {
      "types": "./dist/esm/schema/arktype.d.ts",
      "require": "./dist/cjs/schema/arktype.cjs",
      "import": "./dist/esm/schema/arktype.js"
    },
    "./schema/typebox": {
      "types": "./dist/esm/schema/typebox.d.ts",
      "require": "./dist/cjs/schema/typebox.cjs",
      "import": "./dist/esm/schema/typebox.js"
    },
    "./schema/valibot": {
      "types": "./dist/esm/schema/valibot.d.ts",
      "require": "./dist/cjs/schema/valibot.cjs",
      "import": "./dist/esm/schema/valibot.js"
    },
    "./schema/yup": {
      "types": "./dist/esm/schema/yup.d.ts",
      "require": "./dist/cjs/schema/yup.cjs",
      "import": "./dist/esm/schema/yup.js"
    },
    "./schema/zod": {
      "types": "./dist/esm/schema/zod.d.ts",
      "require": "./dist/cjs/schema/zod.cjs",
      "import": "./dist/esm/schema/zod.js"
    },
    "./schema/superstruct": {
      "types": "./dist/esm/schema/superstruct.d.ts",
      "require": "./dist/cjs/schema/superstruct.cjs",
      "import": "./dist/esm/schema/superstruct.js"
    }
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "test": "bun test ./tests",
    "test:watch": "bun test --watch ./tests",
    "types": "tsc --noEmit -p tsconfig.build.json",
    "typesgo": "tsgo --noEmit -p tsconfig.build.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "pack:dist": "rimraf ../../packages-dist-npm && bun ../../scripts/transform-package-for-publish.ts && mkdir -p ../../packages-dist-npm/core && npm pack --pack-destination ../../packages-dist-npm/core --silent && (cd ../../packages-dist-npm/core && tar -xzf *.tgz && cp -r package/* . && rm -rf package && rm *.tgz) && bun ../../scripts/restore-package.ts",
    "prepublishOnly": "bun ../../scripts/transform-package-for-publish.ts",
    "postpublish": "bun ../../scripts/restore-package.ts"
  },
  "dependencies": {
    "@standard-schema/spec": "^1.1.0",
    "safe-stable-stringify": "^2.5.0",
    "use-context-selector": "^2.0.0"
  },
  "peerDependencies": {
    "@devp0nt/flat0": "catalog:",
    "@devp0nt/route0": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@unhead/react": "catalog:",
    "react": "catalog:"
  },
  "devDependencies": {
    "@devp0nt/flat0": "catalog:",
    "@devp0nt/route0": "catalog:",
    "@sinclair/typebox": "catalog:",
    "@types/bun": "^1.2.22",
    "@types/node": "^20.0.0",
    "@unhead/react": "catalog:",
    "@valibot/to-json-schema": "^1.6.0",
    "arktype": "catalog:",
    "esbuild-fix-imports-plugin": "^1.0.22",
    "react": "catalog:",
    "superjson": "^2.2.6",
    "superstruct": "catalog:",
    "tsup": "^8.0.0",
    "typescript": "catalog:",
    "valibot": "catalog:",
    "yup": "catalog:",
    "zod": "catalog:"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
